@model NIF_Builders.Models.ViewModels.ProjectVM
@{
    ViewBag.Title = "Delete Project";
}

<div class="row mt-4">
    <div class="col-12 text-center mb-4">
        <h2 class="display-5 fw-bold text-danger">🗑️ Delete Project</h2>
        <p class="text-muted">Review the project and its assigned machinery before permanent deletion.</p>
    </div>

    <div class="col-12">
        <div class="alert alert-danger shadow-sm border-danger text-center mb-4 mx-auto" style="max-width: 800px;">
            <h5 class="mb-1 fw-bold">⚠️ Are you sure you want to delete this project?</h5>
            <small>This action cannot be undone. All site data will be erased and assigned machinery will be returned to the available fleet.</small>
        </div>

        @using (Html.BeginForm("Delete", "Projects", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-top: 5px solid #dc3545;">
                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">📋 Project Details</h4>
                            <span class="badge bg-danger text-white border border-light">Project #@Model.ProjectID</span>
                        </div>
                        <div class="card-body bg-light">

                            @Html.HiddenFor(x => x.ProjectID)

                            <div class="row mb-3">
                                @Html.LabelFor(x => x.ProjectName, htmlAttributes: new { @class = "col-form-label fw-bold col-4" })
                                <div class="col-8">
                                    @Html.TextBoxFor(x => x.ProjectName, new { @class = "form-control bg-white", @readonly = "readonly" })
                                </div>
                            </div>

                            <div class="row mb-3">
                                @Html.LabelFor(x => x.StartDate, htmlAttributes: new { @class = "col-form-label fw-bold col-4" })
                                <div class="col-8">
                                    @Html.TextBoxFor(x => x.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control bg-white", type = "date", @readonly = "readonly" })
                                </div>
                            </div>

                            <div class="row mb-3">
                                @Html.LabelFor(x => x.EstimateEndDate, htmlAttributes: new { @class = "col-form-label fw-bold col-4" })
                                <div class="col-8">
                                    @Html.TextBoxFor(x => x.EstimateEndDate, "{0:yyyy-MM-dd}", new { @class = "form-control bg-white", type = "date", @readonly = "readonly" })
                                </div>
                            </div>

                            <div class="row mb-3">
                                @Html.LabelFor(x => x.EstimatedDays, htmlAttributes: new { @class = "col-form-label fw-bold col-4" })
                                <div class="col-8">
                                    @Html.TextBoxFor(x => x.EstimatedDays, new { @class = "form-control bg-white", type = "number", @readonly = "readonly" })
                                </div>
                            </div>

                            <div class="row mb-3">
                                @Html.LabelFor(x => x.ProjectDocumentFile, "Site Document", htmlAttributes: new { @class = "col-form-label fw-bold col-4" })
                                <div class="col-8">
                                    @if (!string.IsNullOrEmpty(Model.ProjectDocuments))
                                    {
                                        <div class="p-2 border border-danger rounded bg-white d-flex align-items-center">
                                            <img src="@Model.ProjectDocuments" width="40" height="40" style="border-radius:4px; object-fit: cover; border: 1px solid #ccc;" alt="Current Doc" />
                                            <div class="ms-2">
                                                <small class="text-danger fw-bold d-block">Attached file will be deleted</small>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="form-control bg-white text-muted">No document attached</div>
                                    }
                                </div>
                            </div>

                            <div class="row mb-3">
                                @Html.LabelFor(x => x.WorkInProgress, htmlAttributes: new { @class = "col-form-label fw-bold col-4" })
                                <div class="col-8 d-flex align-items-center">
                                    <div class="form-check form-switch fs-5">
                                        @Html.CheckBoxFor(x => x.WorkInProgress, new { @class = "form-check-input", @disabled = "disabled" })
                                    </div>
                                </div>
                            </div>

                            <hr />
                            <div class="row">
                                <div class="col-12 d-flex justify-content-between align-items-center">
                                    <a href="@Url.Action("Index", "Projects")" class="btn btn-outline-secondary fw-bold px-4">⬅️ Cancel</a>
                                    <button type="submit" class="btn btn-danger fw-bold px-4 shadow-sm">❌ Confirm Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-top: 5px solid #343a40;">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 text-dark">🚜 Assigned Equipment</h4>
                            <span class="badge bg-secondary">Releasing Assets</span>
                        </div>
                        <div class="card-body">
                            <p class="text-danger small mb-4 fw-bold">Deleting this project will release the following machinery back into the available fleet.</p>

                            <div id="equipmentContainer" style="pointer-events: none; opacity: 0.8;">
                                @if (Model.EquipmentList != null && Model.EquipmentList.Any())
                                {
                                    foreach (var item in Model.EquipmentList)
                                    {
                                        @Html.Action("AddNewEquipment", "Projects", new { id = item })
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-secondary text-center small border-secondary">No machinery currently assigned to this project.</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>