@{
    ViewBag.Title = "Contact NIF Builders";
}

<main aria-labelledby="title" class="container mt-4">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 id="title" class="display-4 fw-bold">@ViewBag.Title</h2>
            <h3 class="text-muted fs-4">@ViewBag.Message</h3>
            <div style="height: 4px; width: 80px; background-color: #ffc107; margin: 20px auto;"></div>
            <p class="lead">Have a question about an upcoming project or need to coordinate equipment logistics? Reach out to our dispatch and management teams.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h4 class="card-title mb-4" style="color: #343a40;">📍 Headquarters</h4>

                    <address class="mb-4" style="font-size: 1.1rem;">
                        <strong>NIF Builders Corporate Office</strong><br />
                        Nakibul Islam Fahim - 1294701.<br />
                        WADA/PNTL-M/69/01<br />
                        911 East Shewrapara, Kafrul, Dhaka-1216
                    </address>

                    <address style="font-size: 1.1rem;">
                        <strong>📞 Dispatch & Support:</strong> <a href="tel:+8801550446262" class="text-decoration-none text-dark fw-bold">+8801550446262</a><br />
                        <strong>✉️ Project Inquiries:</strong> <a href="mailto:projects@nifbuilders.com" class="text-decoration-none text-primary">projects@nifbuilders.com</a><br />
                        <strong>✉️ Equipment Fleet:</strong> <a href="mailto:dispatch@nifbuilders.com" class="text-decoration-none text-primary">dispatch@nifbuilders.com</a>
                    </address>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0 text-white bg-dark">
                <div class="card-body p-4">
                    <h4 class="card-title mb-4" style="color: #ffc107;">⏱️ Operating Hours</h4>

                    <ul class="list-unstyled" style="font-size: 1.1rem;">
                        <li class="d-flex justify-content-between mb-2 pb-2 border-bottom border-secondary">
                            <span>Monday - Friday</span>
                            <span>6:00 AM - 6:00 PM</span>
                        </li>
                        <li class="d-flex justify-content-between mb-2 pb-2 border-bottom border-secondary">
                            <span>Saturday (Site Work Only)</span>
                            <span>7:00 AM - 3:00 PM</span>
                        </li>
                        <li class="d-flex justify-content-between mb-2 pb-2">
                            <span>Sunday</span>
                            <span class="text-warning">Closed</span>
                        </li>
                    </ul>

                    <div class="mt-4 p-3 bg-secondary rounded text-center">
                        <small><em>For emergency site issues outside of standard operating hours, please contact the on-call site supervisor directly via the internal portal.</em></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>