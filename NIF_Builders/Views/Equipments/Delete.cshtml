@model NIF_Builders.Models.Equipment

@{
    ViewBag.Title = "Delete Machinery";
}

<div class="row mt-4 justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold text-danger">🗑️ Delete Machinery</h2>
            <p class="text-muted">Remove a heavy asset from the NIF Builders fleet inventory.</p>
        </div>

        <div class="card shadow-sm border-0" style="border-top: 5px solid #dc3545;">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0 text-warning">⚠️ Confirm Deletion</h4>
            </div>

            <div class="card-body bg-light p-4">
                <div class="alert alert-danger shadow-sm border-danger text-center mb-4">
                    <h5 class="mb-1 fw-bold">Are you sure you want to delete this asset?</h5>
                    <small>This action cannot be undone and will permanently remove this machinery from the fleet.</small>
                </div>

                <div class="mb-4 p-3 bg-white border rounded shadow-sm text-center">
                    <span class="text-muted fw-bold d-block mb-2 text-uppercase" style="letter-spacing: 1px;">Machinery Name / Model</span>
                    <span class="fs-4 fw-bold text-dark">🚜 @Html.DisplayFor(model => model.EquipmentName)</span>
                </div>

                <hr class="text-secondary mb-4" />

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary fw-bold px-4">
                            ⬅️ Cancel
                        </a>
                        <button type="submit" class="btn btn-danger fw-bold px-4 shadow-sm">
                            🗑️ Delete Asset
                        </button>
                    </div>
                }
            </div>
        </div>

    </div>
</div>