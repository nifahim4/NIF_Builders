@model NIF_Builders.Models.Equipment

@{
    ViewBag.Title = "Edit Machinery";
}

<div class="row mt-4 justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold">✏️ Edit Machinery</h2>
            <p class="text-muted">Update details for an existing heavy asset in the NIF Builders fleet.</p>
        </div>

        <div class="card shadow-sm border-0" style="border-top: 5px solid #ffc107;">
            <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                <h4 class="mb-0">🚜 Equipment Details</h4>
                <span class="badge bg-warning text-dark fs-6 px-3 py-2 border border-dark">Asset #@Model.EquipmentID</span>
            </div>

            <div class="card-body bg-light p-4">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    @Html.HiddenFor(model => model.EquipmentID)

                    <div class="mb-4">
                        @Html.LabelFor(model => model.EquipmentName, "Machinery Name / Model", htmlAttributes: new { @class = "form-label fw-bold text-dark" })
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-warning text-dark border-warning" title="Asset Name">🏷️</span>

                            @Html.EditorFor(model => model.EquipmentName, new { htmlAttributes = new { @class = "form-control border-warning shadow-none" } })
                        </div>
                        @Html.ValidationMessageFor(model => model.EquipmentName, "", new { @class = "text-danger small mt-1 d-block fw-bold" })
                    </div>

                    <hr class="text-secondary mb-4" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary fw-bold">
                            ⬅️ Back to Fleet
                        </a>
                        <button type="submit" class="btn btn-warning fw-bold text-dark px-4 border-dark">
                            💾 Save Changes
                        </button>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}